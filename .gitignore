# Environment and credentials — never commit
config/env.php

# User uploaded files — never commit
uploads/*
!uploads/.gitkeep

# Generated thumbnails — never commit
public/assets/thumbnails/*
!public/assets/thumbnails/.gitkeep

# Public assets cache
public/assets/*
!public/assets/.gitkeep

# PHP dependencies (if Composer is added later)
vendor/

# macOS artifacts
.DS_Store
.AppleDouble
.LSOverride

# Windows artifacts
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor artifacts
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Compiled or cached output
*.cache